NEXT_PUBLIC_REMARK42_LOCALE=bp
NEXT_PUBLIC_REMARK42_NO_FOOTER=true

# Optional: enables the server-side Chat GPT assistant for draw analysis. Keep the real key out of git.
OPENAI_API_KEY=
