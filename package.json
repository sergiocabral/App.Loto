{
  "name": "app-loto-next",
  "version": "2.0.0",
  "private": true,
  "scripts": {
    "dev": "node scripts/run-next.cjs dev",
    "build": "next build",
    "start": "node scripts/run-next.cjs start",
    "preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "deploy": "opennextjs-cloudflare build && opennextjs-cloudflare deploy",
    "upload": "opennextjs-cloudflare build && opennextjs-cloudflare upload",
    "cloudflare:build": "opennextjs-cloudflare build",
    "cloudflare:check": "opennextjs-cloudflare build && wrangler deploy --dry-run",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts",
    "lint": "eslint",
    "test": "NODE_ENV=test vitest run --project node --project jsdom --project postgres --coverage.enabled",
    "test:watch": "NODE_ENV=test vitest --project node --project jsdom",
    "db:migrate": "node scripts/migrate.cjs"
  },
  "dependencies": {
    "dotenv": "^17.4.2",
    "next": "16.2.6",
    "pg": "^8.20.0",
    "pg-cloudflare": "^1.3.0",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@opennextjs/cloudflare": "^1.19.4",
    "@testcontainers/postgresql": "^12.0.4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^4.1.5",
    "esbuild": "^0.28.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "jsdom": "^29.1.1",
    "typescript": "^5",
    "vitest": "^4.1.5",
    "wrangler": "^4.103.0"
  },
  "overrides": {
    "fast-xml-builder": "1.2.0",
    "postcss": "8.5.12"
  }
}
